# Địa chỉ API Backend (thay port cho đúng với máy của bạn)
REACT_APP_API_URL=https://localhost:7030/api

# Địa chỉ gốc để tải hình ảnh từ Backend
REACT_APP_IMAGE_BASE_URL=https://localhost:7030
