@model List<CMS.Data.Entities.Category>

<h2>Danh sách danh mục</h2>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Id</th>
            <th>Tên danh mục</th>
            <th>Mô tả</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Name</td>
                <td>@item.Description</td>
            </tr>
        }
    </tbody>
</table>