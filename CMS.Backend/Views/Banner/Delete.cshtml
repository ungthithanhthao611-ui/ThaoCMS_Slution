@model CMS.Data.Entities.Banner

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Xóa Banner";
}

<div class="container mt-4">
    <div class="card shadow border-danger">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0"><i class="bi bi-exclamation-triangle"></i> XÁC NHẬN XÓA BANNER</h4>
        </div>
        <div class="card-body">
            <h5 class="text-danger">Bạn có chắc chắn muốn xóa Banner này không? Hành động này không thể hoàn tác!</h5>
            <hr />
            
            <div class="row">
                <div class="col-md-4">
                    <img src="@Model.ImageUrl" alt="@Model.Title" style="max-width: 100%; border-radius: 8px; border: 1px solid #ddd;" />
                </div>
                <div class="col-md-8">
                    <table class="table table-bordered">
                        <tr>
                            <th style="width: 150px;">Tiêu đề:</th>
                            <td>@Model.Title</td>
                        </tr>
                        <tr>
                            <th>Mô tả:</th>
                            <td>@Model.Description</td>
                        </tr>
                        <tr>
                            <th>Đường dẫn link:</th>
                            <td>@Model.LinkUrl</td>
                        </tr>
                        <tr>
                            <th>Thứ tự:</th>
                            <td>@Model.DisplayOrder</td>
                        </tr>
                    </table>
                </div>
            </div>

            <hr />
            <form asp-action="Delete" method="post">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-danger"><i class="bi bi-trash"></i> Đồng ý xóa</button>
                    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>
