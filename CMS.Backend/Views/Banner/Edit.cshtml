@model CMS.Data.Entities.Banner

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa Banner";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0"><i class="bi bi-pencil-square"></i> CHỈNH SỬA BANNER QUẢNG CÁO</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="ImageUrl" />

                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tiêu đề Banner:</label>
                            <input asp-for="Title" class="form-control" required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Đường dẫn liên kết (LinkUrl):</label>
                            <input asp-for="LinkUrl" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mô tả hiển thị:</label>
                            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Ảnh hiện tại:</label>
                            <div class="mb-2">
                                <img src="@Model.ImageUrl" alt="@Model.Title" style="max-height: 120px; max-width: 100%; border: 1px solid #ddd; border-radius: 4px;" />
                            </div>
                            <label class="form-label fw-bold">Tải ảnh mới (nếu muốn thay đổi):</label>
                            <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Thứ tự hiển thị:</label>
                            <input asp-for="DisplayOrder" type="number" class="form-control" />
                        </div>

                        <div class="mb-3 form-check form-switch mt-4">
                            <input asp-for="IsActive" type="checkbox" class="form-check-input" id="isActiveSwitch" />
                            <label class="form-check-label fw-bold" for="isActiveSwitch">Kích hoạt hiển thị</label>
                        </div>
                    </div>
                </div>

                <hr />
                <div class="d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Cập nhật</button>
                    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>
