@model CMS.Data.Entities.Banner

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm Banner mới";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white">
            <h4 class="mb-0"><i class="bi bi-plus-circle"></i> THÊM BANNER QUẢNG CÁO MỚI</h4>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="row">
                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tiêu đề Banner:</label>
                            <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề..." required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Đường dẫn liên kết (LinkUrl):</label>
                            <input asp-for="LinkUrl" class="form-control" placeholder="/san-pham hoặc url..." />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mô tả hiển thị:</label>
                            <textarea asp-for="Description" class="form-control" rows="3" placeholder="Nhập mô tả ngắn..."></textarea>
                        </div>
                    </div>

                    <div class="col-md-6">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tải hình ảnh Banner:</label>
                            <input type="file" name="uploadImage" class="form-control" accept="image/*" required />
                            <small class="text-muted">Chọn file ảnh kích thước rộng để làm slide banner.</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Thứ tự hiển thị:</label>
                            <input asp-for="DisplayOrder" type="number" class="form-control" value="0" />
                        </div>

                        <div class="mb-3 form-check form-switch mt-4">
                            <input asp-for="IsActive" type="checkbox" class="form-check-input" id="isActiveSwitch" checked />
                            <label class="form-check-label fw-bold" for="isActiveSwitch">Kích hoạt hiển thị</label>
                        </div>
                    </div>
                </div>

                <hr />
                <div class="d-flex justify-content-end gap-2">
                    <button type="submit" class="btn btn-success"><i class="bi bi-save"></i> Lưu lại</button>
                    <a asp-action="Index" class="btn btn-secondary"><i class="bi bi-arrow-left"></i> Quay lại</a>
                </div>
            </form>
        </div>
    </div>
</div>
