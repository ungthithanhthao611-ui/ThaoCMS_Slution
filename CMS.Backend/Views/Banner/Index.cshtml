@model IEnumerable<CMS.Data.Entities.Banner>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý Banner";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2><i class="bi bi-images"></i> DANH SÁCH BANNER QUẢNG CÁO</h2>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-plus-circle"></i> Thêm Banner Mới</a>
    </div>

    <div class="card shadow">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th style="width: 80px;">Hình ảnh</th>
                        <th>Tiêu đề</th>
                        <th>Liên kết (Link)</th>
                        <th>Thứ tự</th>
                        <th>Trạng thái</th>
                        <th style="width: 200px;">Hành động</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <img src="@item.ImageUrl" alt="@item.Title" style="max-height: 50px; max-width: 100px; border-radius: 4px;" />
                                }
                                else
                                {
                                    <span class="text-muted">Không có ảnh</span>
                                }
                            </td>
                            <td>
                                <strong>@item.Title</strong>
                                @if (!string.IsNullOrEmpty(item.Description))
                                {
                                    <div class="small text-muted">@item.Description</div>
                                }
                            </td>
                            <td><span class="text-muted">@item.LinkUrl</span></td>
                            <td>@item.DisplayOrder</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">Hoạt động</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Khóa</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                    <i class="bi bi-pencil-square"></i> Sửa
                                </a>
                                <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i> Xóa
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
