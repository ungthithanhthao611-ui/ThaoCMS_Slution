@model CMS.Data.Entities.User

@{
    // [BUỔI 4] Cài đặt sử dụng Layout quản trị chung
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm thành viên";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-dark text-white d-flex align-items-center">
            <h5 class="mb-0"><i class="bi bi-person-plus-fill"></i> THÊM THÀNH VIÊN HỆ THỐNG</h5>
        </div>
        <div class="card-body">
            <form asp-action="Create" method="post">
                <!-- Hiển thị toàn bộ lỗi validation nếu có -->
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row">
                    <!-- Ô nhập Tên đăng nhập -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Tên đăng nhập (Username):</label>
                        <input asp-for="Username" class="form-control" placeholder="Ví dụ: admin_thai" required />
                        <!-- Báo lỗi trùng Username nếu Controller gửi lỗi về (Buổi 4) -->
                        <span asp-validation-for="Username" class="text-danger small"></span>
                    </div>
                    
                    <!-- Ô nhập Mật khẩu (Dùng type="password" bảo mật) -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Mật khẩu:</label>
                        <input asp-for="PasswordHash" type="password" class="form-control" placeholder="Nhập mật khẩu..." required />
                        <small class="text-muted">Ở Buổi 4 chúng ta tạm thời lưu mật khẩu dạng văn bản thô.</small>
                    </div>
                </div>

                <div class="row">
                    <!-- Ô nhập Họ và Tên -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Họ và Tên:</label>
                        <input asp-for="FullName" class="form-control" placeholder="Ví dụ: Nguyễn Văn A" required />
                    </div>
                    
                    <!-- Dropdown chọn vai trò để phân quyền Admin/Editor -->
                    <div class="col-md-6 mb-3">
                        <label class="form-label fw-bold">Vai trò (Role):</label>
                        <select asp-for="Role" class="form-select" required>
                            <option value="">-- Chọn quyền hạn --</option>
                            <option value="Admin">Quản trị viên (Admin)</option>
                            <option value="Editor">Biên tập viên (Editor)</option>
                        </select>
                        <small class="text-muted">Quyền quyết định phân chia phân vùng quản trị ở Buổi 5.</small>
                    </div>
                </div>

                <div class="mt-4 pt-2 border-top">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="bi bi-save"></i> Lưu thành viên
                    </button>
                    <a asp-action="Index" class="btn btn-secondary px-4 ms-2">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
