@model List<CMS.Data.Entities.User>

@{
    // [BUỔI 4] Cài đặt sử dụng Layout quản trị chung
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý thành viên";
}

<div class="container mt-4">
    <!-- Tiêu đề và nút thêm thành viên mới - [BUỔI 4] -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold">QUẢN LÝ THÀNH VIÊN</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Thêm thành viên mới
        </a>
    </div>

    <!-- Bảng danh sách thành viên - [BUỔI 3/4] -->
    <table class="table table-bordered table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th>ID</th>
                <th>Tên đăng nhập (Username)</th>
                <th>Họ và tên</th>
                <th>Quyền hạn (Role)</th>
                <th style="width: 180px;">Thao tác</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <!-- [BUỔI 3] Hiển thị các trường dữ liệu của User -->
                    <td>@item.Id</td>
                    <td><strong>@item.Username</strong></td>
                    <td>@item.FullName</td>
                    <td>
                        <!-- [BUỔI 4] Sử dụng nhãn màu đỏ cho Admin và xanh cho Editor để trực quan hóa vai trò -->
                        @if (item.Role == "Admin")
                        {
                            <span class="badge bg-danger">@item.Role</span>
                        }
                        else
                        {
                            <span class="badge bg-info text-dark">@item.Role</span>
                        }
                    </td>
                    <td>
                        <!-- [BUỔI 4] Các nút Sửa/Xóa đi kèm route-id và confirm hộp thoại xóa -->
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-warning">
                            <i class="bi bi-pencil"></i> Sửa
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" 
                           onclick="return confirm('Bạn có chắc chắn muốn xóa thành viên @item.Username không?')">
                            <i class="bi bi-trash"></i> Xóa
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <div class="text-center text-muted my-5">
            <i class="bi bi-people display-1"></i>
            <p class="mt-3">Hệ thống chưa có tài khoản nào. Vui lòng bấm vào thêm mới!</p>
        </div>
    }
</div>