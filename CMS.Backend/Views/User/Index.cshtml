@model IEnumerable<CMS.Data.Entities.User>

@{
    ViewData["Title"] = "Quản lý thành viên";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>QUẢN LÝ THÀNH VIÊN</h3>
        <a href="#" class="btn btn-success btn-sm">+ Thêm thành viên mới</a>
    </div>

    <table class="table table-bordered table-hover">
        <thead class="table-light">
            <tr>
                <th>ID</th>
                <th>Tên Đăng Nhập</th>
                <th>Họ Và Tên</th>
                <th>Quyền Hạn</th>
                <th>Thao Tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td><strong>@item.Username</strong></td>
                    <td>@item.FullName</td>
                    <td>
                        @{
                            var badgeClass = item.Role == "Administrator" ? "bg-danger" :
                            (item.Role == "Editor" ? "bg-info" : "bg-primary");
                        }
                        <span class="badge @badgeClass">@item.Role</span>
                    </td>
                    <td>
                        <button class="btn btn-outline-warning btn-sm">Sửa</button>
                        <button class="btn btn-outline-danger btn-sm">Xóa</button>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>