<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ThaoCMS</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CMS.Backend.styles.css" asp-append-version="true" />
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
            <div class="container-fluid">
                <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                    ThaoCMS
                </a>

                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Home" asp-action="Index">Home</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Category" asp-action="Index">Category</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-controller="Post" asp-action="Index">Post</a>
                        </li>
			<li class="nav-item">
  			  <a class="nav-link text-dark" asp-controller="User" asp-action="Index">User</a>
			</li>
			<li class="nav-item">
   			 <a class="nav-link text-dark" asp-controller="CategoryProduct" asp-action="Index">Category Product</a>
			</li>
<li class="nav-item">
    <a class="nav-link text-dark" asp-controller="Product" asp-action="Index">Product</a>
</li>
<li class="nav-item">
    <a class="nav-link text-dark" asp-controller="Customer" asp-action="Index">Customer</a>
</li>
<li class="nav-item">
    <a class="nav-link text-dark" asp-controller="Order" asp-action="Index">Order</a>
</li>
<li class="nav-item">
    <a class="nav-link text-dark" asp-controller="OrderDetail" asp-action="Index">Order Detail</a>
</li>
<li class="nav-item">
    <a class="nav-link text-dark" asp-controller="Menu" asp-action="Index">Menu</a>
</li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="border-top footer text-muted">
        <div class="container">
            &copy; 2026 - Cao đẳng Công Thương TP.HCM
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>