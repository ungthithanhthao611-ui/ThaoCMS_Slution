@inject CMS.Data.ApplicationDbContext DbContext
@{
    var currentController = ViewContext.RouteData.Values["controller"]?.ToString() ?? "";
    var pendingOrdersCount = DbContext.Orders.Count(o => o.Status == 0);
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ThaoCMS Admin</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css">
    <style>
        /* CSS cho sidebar bên trái của khu vực Admin - BUỔI 4 */
        .sidebar { min-height: 100vh; background-color: #212529; color: white; }
        .sidebar a { color: #adb5bd; text-decoration: none; display: block; padding: 10px 20px; }
        .sidebar a:hover { background-color: #343a40; color: white; }
        .sidebar .active { background-color: #0d6efd; color: white; }
    </style>
</head>
<body>
    <div class="container-fluid">
        <div class="row">
            <!-- Sidebar điều hướng bên trái - BUỔI 4 & 5 -->
            <nav class="col-md-3 col-lg-2 sidebar p-0 d-flex flex-column justify-content-between">
                <div>
                    <div class="p-3 text-center border-bottom border-secondary">
                        <h4 class="text-white">ThaoCMS Admin</h4>
                    </div>
                    <div class="mt-3">
                        <a asp-controller="Home" asp-action="Index" class="@(currentController.Equals("Home", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                            <i class="bi bi-speedometer2"></i> Bảng điều khiển
                        </a>
                        <a asp-controller="Category" asp-action="Index" class="@(currentController.Equals("Category", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                            <i class="bi bi-grid"></i> Quản lý danh mục tin tức
                        </a>
                        <a asp-controller="Post" asp-action="Index" class="@(currentController.Equals("Post", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                            <i class="bi bi-file-earmark-post"></i> Quản lý Bài viết
                        </a>
                        <a asp-controller="About" asp-action="Index" class="@(currentController.Equals("About", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                            <i class="bi bi-info-circle"></i> Quản lý Giới thiệu
                        </a>
                        <a asp-controller="User" asp-action="Index" class="@(currentController.Equals("User", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                            <i class="bi bi-people"></i> Quản lý Thành viên
                        </a>
                        <!-- Các trang nghiệp vụ nâng cao bổ sung - BUỔI 4 & 5 -->
                        <a asp-controller="CategoryProduct" asp-action="Index" class="@(currentController.Equals("CategoryProduct", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                            <i class="bi bi-tags"></i> Loại sản phẩm
                        </a>
                        <a asp-controller="Product" asp-action="Index" class="@(currentController.Equals("Product", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                            <i class="bi bi-box-seam"></i> Sản phẩm
                        </a>
                        <a asp-controller="Customer" asp-action="Index" class="@(currentController.Equals("Customer", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                            <i class="bi bi-person-vcard"></i> Khách hàng
                        </a>
                        <a asp-controller="Order" asp-action="Index" class="d-flex justify-content-between align-items-center @(currentController.Equals("Order", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                            <span><i class="bi bi-receipt"></i> Đơn hàng</span>
                            @if (pendingOrdersCount > 0)
                            {
                                <span class="badge bg-danger rounded-pill">@pendingOrdersCount</span>
                            }
                        </a>
                        <a asp-controller="OrderDetail" asp-action="Index" class="@(currentController.Equals("OrderDetail", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                            <i class="bi bi-list-check"></i> Đơn hàng chi tiết
                        </a>
                        <a asp-controller="Banner" asp-action="Index" class="@(currentController.Equals("Banner", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                            <i class="bi bi-images"></i> Quản lý Banner
                        </a>
                        <a asp-controller="Menu" asp-action="Index" class="@(currentController.Equals("Menu", StringComparison.OrdinalIgnoreCase) ? "active" : "")">
                            <i class="bi bi-menu-button-wide"></i> Quản lý Menu
                        </a>
                    </div>
                </div>

                <!-- [BUỔI 5] Khối hiển thị thông tin tài khoản đang đăng nhập và nút Đăng xuất ở chân Sidebar -->
                @if (User.Identity.IsAuthenticated)
                {
                    <div class="p-3 border-top border-secondary bg-dark">
                        <div class="d-flex align-items-center gap-2 mb-2">
                            <div class="bg-primary text-white rounded-circle d-flex align-items-center justify-content-center" style="width: 36px; height: 36px; min-width: 36px;">
                                <i class="bi bi-person-circle fs-5"></i>
                            </div>
                            <div class="overflow-hidden">
                                <div class="fw-bold text-white text-truncate" style="font-size: 0.95rem;" title="@User.FindFirst("FullName")?.Value">
                                    @User.FindFirst("FullName")?.Value
                                </div>
                                <div class="text-muted" style="font-size: 0.8rem;">
                                    <span class="badge bg-secondary text-light">@User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value</span>
                                </div>
                            </div>
                        </div>
                        <a class="btn btn-sm btn-outline-danger w-100 mt-2 d-flex align-items-center justify-content-center gap-1" asp-controller="Account" asp-action="Logout">
                            <i class="bi bi-box-arrow-right"></i> Đăng xuất
                        </a>
                    </div>
                }
            </nav>

            <!-- Vùng nội dung chính bên phải - BUỔI 4 -->
            <main class="col-md-9 col-lg-10 ms-sm-auto p-4">
                @RenderBody() 
            </main>
        </div>
    </div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
