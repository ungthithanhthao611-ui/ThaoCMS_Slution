@model List<CMS.Data.Entities.Menu>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý Menu";
}

<div>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>DANH SÁCH MENU</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Thêm menu mới
        </a>
    </div>
    <hr />

    <table class="table">
        <thead>
            <tr>
                <th style="width: 80px;">ID</th>
                <th>Tên Menu</th>
                <th>Đường dẫn (Link Url)</th>
                <th style="width: 120px;">Thứ tự hiển thị</th>
                <th>Menu cha</th>
                <th style="width: 150px;">Trạng thái</th>
                <th style="width: 180px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @if (Model != null && Model.Any())
            {
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Id</td>
                        <td class="fw-bold">@item.Name</td>
                        <td><code>@item.LinkUrl</code></td>
                        <td class="text-center">@item.DisplayOrder</td>
                        <td>
                            @(item.Parent != null ? item.Parent.Name : "Không có")
                        </td>
                        <td>
                            @if (item.IsActive)
                            {
                                <span class="badge bg-success"><i class="bi bi-eye"></i> Hiển thị</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary"><i class="bi bi-eye-slash"></i> Ẩn</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">
                                <i class="bi bi-pencil-square"></i> Sửa
                            </a>
                            <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">
                                <i class="bi bi-trash"></i> Xóa
                            </a>
                        </td>
                    </tr>
                }
            }
            else
            {
                <tr>
                    <td colspan="7" class="text-center text-muted">Chưa có menu nào được khởi tạo.</td>
                </tr>
            }
        </tbody>
    </table>
</div>
