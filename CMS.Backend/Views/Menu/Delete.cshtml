@model CMS.Data.Entities.Menu

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Xác nhận xóa menu";
}

<div class="container mt-4">
    <div class="card shadow border-danger">
        <div class="card-header bg-danger text-white">
            <h4 class="mb-0 fw-bold"><i class="bi bi-exclamation-triangle-fill"></i> XÁC NHẬN XÓA MENU</h4>
        </div>
        <div class="card-body">
            <h5 class="text-danger mb-4">Bạn có chắc chắn muốn xóa menu này không? Hành động này không thể hoàn tác!</h5>
            
            <table class="table table-bordered">
                <tr>
                    <th style="width: 200px;" class="table-light">ID</th>
                    <td>@Model.Id</td>
                </tr>
                <tr>
                    <th class="table-light">Tên Menu</th>
                    <td class="fw-bold text-primary">@Model.Name</td>
                </tr>
                <tr>
                    <th class="table-light">Đường dẫn (Link URL)</th>
                    <td><code>@Model.LinkUrl</code></td>
                </tr>
                <tr>
                    <th class="table-light">Thứ tự hiển thị</th>
                    <td>@Model.DisplayOrder</td>
                </tr>
                <tr>
                    <th class="table-light">Menu cha</th>
                    <td>@(Model.Parent != null ? Model.Parent.Name : "Không có")</td>
                </tr>
                <tr>
                    <th class="table-light">Trạng thái</th>
                    <td>
                        @if (Model.IsActive)
                        {
                            <span class="badge bg-success">Hiển thị</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Ẩn</span>
                        }
                    </td>
                </tr>
            </table>

            <form asp-action="Delete" method="post" class="mt-4">
                <input type="hidden" asp-for="Id" />
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-danger">
                        <i class="bi bi-trash"></i> Đồng ý xóa
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại danh sách
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>
