@model CMS.Data.Entities.Menu

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa menu";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark">
            <h4 class="mb-0 fw-bold">CHỈNH SỬA MENU</h4>
        </div>
        <div class="card-body">
            <form asp-action="Edit" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>
                <input type="hidden" asp-for="Id" />

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold">Tên Menu</label>
                    <input asp-for="Name" class="form-control" placeholder="Nhập tên hiển thị" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="LinkUrl" class="form-label fw-bold">Đường dẫn (Link URL)</label>
                    <input asp-for="LinkUrl" class="form-control" placeholder="Nhập đường dẫn" />
                    <span asp-validation-for="LinkUrl" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="DisplayOrder" class="form-label fw-bold">Thứ tự hiển thị</label>
                    <input asp-for="DisplayOrder" type="number" class="form-control" />
                    <span asp-validation-for="DisplayOrder" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="ParentId" class="form-label fw-bold">Menu cha (Không bắt buộc)</label>
                    <select asp-for="ParentId" class="form-select" asp-items="ViewBag.ParentId">
                        <option value="">-- Chọn menu cha (Nếu có) --</option>
                    </select>
                    <span asp-validation-for="ParentId" class="text-danger"></span>
                </div>

                <div class="mb-3 form-check form-switch">
                    <input type="hidden" name="IsActive" value="false" />
                    <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                    <label asp-for="IsActive" class="form-check-label fw-bold">Kích hoạt hiển thị</label>
                </div>

                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-warning text-dark fw-bold">
                        <i class="bi bi-save"></i> Cập nhật
                    </button>
                    <a asp-action="Index" class="btn btn-secondary">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
