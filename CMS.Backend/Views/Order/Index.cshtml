@model List<CMS.Data.Entities.Order>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold">DANH SÁCH ĐƠN HÀNG</h2>
    </div>

    <table class="table table-bordered table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th style="width: 80px;">ID</th>
                <th>Mã khách hàng (Customer ID)</th>
                <th>Ngày đặt hàng</th>
                <th>Trạng thái đơn hàng</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Id</strong></td>
                    <td><span class="badge bg-light text-dark border">@item.CustomerId</span></td>
                    <td class="text-muted">@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        @if (item.Status == 2)
                        {
                            <span class="badge bg-success">Đã xong</span>
                        }
                        else if (item.Status == 1)
                        {
                            <span class="badge bg-info text-dark">Đang giao</span>
                        }
                        else if (item.Status == 0)
                        {
                            <span class="badge bg-warning text-dark">Chờ duyệt</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Khác (@item.Status)</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <div class="text-center text-muted my-5">
            <i class="bi bi-receipt display-3"></i>
            <p class="mt-3">Hệ thống chưa có đơn hàng nào.</p>
        </div>
    }
</div>