@model List<CMS.Data.Entities.Order>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý đơn hàng";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold">DANH SÁCH ĐƠN HÀNG</h2>
    </div>

    <table class="table table-bordered table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th style="width: 80px;">ID</th>
                <th>Khách hàng</th>
                <th>Ngày đặt hàng</th>
                <th>Trạng thái đơn hàng</th>
                <th style="width: 280px; text-align: center;">Thao tác</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Id</strong></td>
                    <td>
                        <div class="fw-bold text-dark">@(item.Customer?.FullName ?? "Khách hàng không tồn tại")</div>
                        <small class="text-secondary d-block">Email: @(item.Customer?.Email ?? "N/A") | SĐT: @(item.Customer?.Phone ?? "N/A")</small>
                    </td>
                    <td class="text-muted">@item.OrderDate.ToString("dd/MM/yyyy HH:mm")</td>
                    <td>
                        @if (item.Status == 2)
                        {
                            <span class="badge bg-success shadow-sm">Đã xong</span>
                        }
                        else if (item.Status == 1)
                        {
                            <span class="badge bg-info text-dark shadow-sm">Đang giao</span>
                        }
                        else if (item.Status == 0)
                        {
                            <span class="badge bg-warning text-dark shadow-sm">Chờ duyệt</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary shadow-sm">Khác (@item.Status)</span>
                        }
                    </td>
                    <td class="text-center">
                        <!-- Cập nhật trạng thái bằng Dropdown Select -->
                        <select class="form-select form-select-sm d-inline-block w-auto me-2 shadow-sm" 
                                onchange="location.href='@Url.Action("UpdateStatus", "Order")?id=' + @item.Id + '&status=' + this.value">
                            <!option value="0" @(item.Status == 0 ? "selected" : "")>Chờ duyệt</!option>
                            <!option value="1" @(item.Status == 1 ? "selected" : "")>Đang giao</!option>
                            <!option value="2" @(item.Status == 2 ? "selected" : "")>Đã xong</!option>
                        </select>

                        <!-- Nút xem chi tiết đơn hàng -->
                        <a href="/OrderDetail?orderId=@item.Id" 
                           class="btn btn-sm btn-info text-dark shadow-sm me-2" 
                           title="Xem chi tiết đơn hàng">
                            <i class="bi bi-eye"></i> Chi tiết
                        </a>

                        <!-- Nút xóa đơn hàng -->
                        <a href="@Url.Action("Delete", "Order", new { id = item.Id })" 
                           class="btn btn-sm btn-danger shadow-sm" 
                           onclick="return confirm('Bạn có chắc chắn muốn xóa đơn hàng này và các chi tiết liên quan không?');">
                            <i class="bi bi-trash"></i> Xóa
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <div class="text-center text-muted my-5">
            <i class="bi bi-receipt display-3"></i>
            <p class="mt-3">Hệ thống chưa có đơn hàng nào.</p>
        </div>
    }
</div>