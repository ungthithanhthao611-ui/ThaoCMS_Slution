@model List<CMS.Data.Entities.Customer>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý khách hàng";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold">DANH SÁCH KHÁCH HÀNG</h2>
    </div>

    <table class="table table-bordered table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th style="width: 80px;">ID</th>
                <th>Họ và tên</th>
                <th>Email</th>
                <th>Số điện thoại</th>
                <th>Địa chỉ</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Id</strong></td>
                    <td class="text-primary fw-semibold">@item.FullName</td>
                    <td><a href="mailto:@item.Email" class="text-decoration-none">@item.Email</a></td>
                    <td><span class="badge bg-light text-dark border">@item.Phone</span></td>
                    <td class="text-muted">@item.Address</td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <div class="text-center text-muted my-5">
            <i class="bi bi-people display-3"></i>
            <p class="mt-3">Hệ thống chưa có khách hàng nào.</p>
        </div>
    }
</div>