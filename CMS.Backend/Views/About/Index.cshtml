@model List<CMS.Data.Entities.About>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý bài giới thiệu";
}

<div>
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2>QUẢN LÝ BÀI GIỚI THIỆU (ABOUT US)</h2>
        <a asp-action="Create" class="btn btn-success">
            + Thêm phân khu mới
        </a>
    </div>
    <hr />

    <table class="table">
        <thead>
            <tr>
                <th>Phân khu (Section)</th>
                <th>Tiêu đề chính</th>
                <th>Tiêu đề phụ</th>
                <th>Nội dung đoạn giới thiệu</th>
                <th>Hình ảnh minh họa (URL)</th>
                <th style="width:150px;">Thao tác</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td class="fw-bold text-success">@item.SectionName</td>
                    <td class="fw-bold">@item.Title</td>
                    <td class="text-muted">@item.Subtitle</td>
                    <td>@item.Content</td>
                    <td>
                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                        {
                            <img src="@item.ImageUrl" style="max-height: 60px; border-radius: 4px;" alt="About image" />
                            <br />
                            <small class="text-muted text-break">@item.ImageUrl</small>
                        }
                        else
                        {
                            <span class="text-danger">Không có ảnh</span>
                        }
                    </td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-warning btn-sm">Sửa</a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Xóa</a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>
