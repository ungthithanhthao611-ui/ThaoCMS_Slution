@using X.PagedList.Mvc.Core
@using X.PagedList.Web.Common
@model X.PagedList.IPagedList<CMS.Data.Entities.Product>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div>
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>DANH SÁCH SẢN PHẨM</h2>
        <div>
            <a asp-action="RecycleBin" class="btn btn-outline-danger me-2 shadow-sm">
                <i class="bi bi-trash"></i> Thùng rác @(ViewBag.TrashCount > 0 ? $"({ViewBag.TrashCount})" : "")
            </a>
            <a asp-action="Create" class="btn btn-success shadow-sm">
                <i class="bi bi-plus-circle"></i> Thêm sản phẩm
            </a>
        </div>
    </div>

    @if (TempData["SuccessMsg"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i> @TempData["SuccessMsg"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    @if (TempData["ErrorMsg"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i> <strong>Lỗi xóa:</strong> @TempData["ErrorMsg"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <table class="table align-middle">
        <thead>
            <tr>
                <th style="width: 70px;">ID</th>
                <th>Hình ảnh</th>
                <th>Tên sản phẩm</th>
                <th>Loại sản phẩm</th>
                <th>Giá bán / Sale</th>
                <th style="width: 120px;">Số lượng kho</th>
                <th style="width: 220px;">Trạng thái</th>
                <th style="width: 180px;" class="text-center">Hành động</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Id</strong></td>
                    <td class="text-center" style="width: 100px;">
                        <img src="@item.ImageUrl" alt="@item.Name" class="img-thumbnail" style="max-height: 60px; max-width: 90px; object-fit: cover;" onerror="this.onerror=null; this.src='https://placehold.co/100x60?text=No+Image'" />
                    </td>
                    <td style="color: #4a2c11; font-weight: 700;">@item.Name</td>
                    <td>
                        @if (item.CategoryProduct != null)
                        {
                            <span class="badge bg-info text-dark">@item.CategoryProduct.Name</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary">Không xác định</span>
                        }
                    </td>
                    <td>
                        @if (item.IsPromo && item.SalePrice.HasValue && item.SalePrice.Value < item.Price)
                        {
                            <div>
                                <span class="text-danger fw-bold">@item.SalePrice.Value.ToString("#,##0") đ</span>
                                <br />
                                <small class="text-muted text-decoration-line-through">@item.Price.ToString("#,##0") đ</small>
                            </div>
                        }
                        else
                        {
                            <span class="text-dark fw-bold">@item.Price.ToString("#,##0") đ</span>
                        }
                    </td>
                    <td>
                        @if (item.StockQuantity <= 5)
                        {
                            <span class="badge bg-warning text-dark">Chỉ còn @item.StockQuantity</span>
                        }
                        else
                        {
                            <span class="badge bg-success">@item.StockQuantity</span>
                        }
                    </td>
                    <td>
                        <div class="d-flex flex-column gap-2" style="font-size: 0.9rem;">
                            <!-- Mới (New) Switch -->
                            <div class="form-check form-switch">
                                <input class="form-check-input status-toggle" type="checkbox" role="switch" 
                                       data-id="@item.Id" data-type="IsNew" @(item.IsNew ? "checked" : "") id="switch-new-@item.Id">
                                <label class="form-check-label text-muted" for="switch-new-@item.Id">Mới (New)</label>
                            </div>
                            
                            <!-- Bán chạy Switch -->
                            <div class="form-check form-switch">
                                <input class="form-check-input status-toggle" type="checkbox" role="switch" 
                                       data-id="@item.Id" data-type="IsBestSeller" @(item.IsBestSeller ? "checked" : "") id="switch-best-@item.Id">
                                <label class="form-check-label text-muted" for="switch-best-@item.Id">Bán chạy</label>
                            </div>
                            
                            <!-- Khuyến mãi Switch -->
                            <div class="form-check form-switch d-flex align-items-center gap-2">
                                <input class="form-check-input promo-toggle" type="checkbox" role="switch" 
                                       data-id="@item.Id" data-type="IsPromo" data-price="@item.Price" @(item.IsPromo ? "checked" : "") id="switch-promo-@item.Id">
                                <label class="form-check-label text-muted m-0" for="switch-promo-@item.Id">Khuyến mãi</label>
                                
                                <span id="promo-badge-@item.Id" class="badge bg-warning text-dark @(item.IsPromo ? "" : "d-none")">
                                    @{
                                        if (item.IsPromo && item.SalePrice.HasValue && item.Price > 0)
                                        {
                                            var pct = Math.Round(((item.Price - item.SalePrice.Value) / item.Price) * 100);
                                            @($"{pct}%")
                                        }
                                    }
                                </span>
                            </div>
                        </div>
                    </td>
                    <td class="text-center">
                        <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning me-1">
                            <i class="bi bi-pencil-square"></i> Sửa
                        </a>
                        <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-outline-danger" onclick="return confirm('Sản phẩm này sẽ được chuyển vào thùng rác. Bạn có chắc chắn?')">
                            <i class="bi bi-trash"></i> Thùng rác
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <div class="text-center text-muted my-5">
            <i class="bi bi-box display-3"></i>
            <p class="mt-3">Hệ thống chưa có sản phẩm nào.</p>
        </div>
    }

    <!-- Nút phân trang (Pagination) -->
    <div class="d-flex justify-content-center mt-4">
        @Html.PagedListPager(Model, page => Url.Action("Index", new { page }), new PagedListRenderOptions
        {
            LiElementClasses = new string[] { "page-item" },
            PageClasses = new string[] { "page-link" },
            DisplayLinkToFirstPage = X.PagedList.Web.Common.PagedListDisplayMode.Always,
            DisplayLinkToLastPage = X.PagedList.Web.Common.PagedListDisplayMode.Always,
            DisplayLinkToPreviousPage = X.PagedList.Web.Common.PagedListDisplayMode.Always,
            DisplayLinkToNextPage = X.PagedList.Web.Common.PagedListDisplayMode.Always,
            MaximumPageNumbersToDisplay = 5
        })
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            // Xử lý bật tắt Mới (New) & Bán chạy
            $('.status-toggle').on('change', function() {
                var checkbox = $(this);
                var id = checkbox.data('id');
                var type = checkbox.data('type');
                
                $.ajax({
                    url: '/Product/ToggleStatus',
                    type: 'POST',
                    data: { id: id, type: type },
                    success: function(res) {
                        if (res.success) {
                            console.log('Cập nhật trạng thái thành công:', type);
                        } else {
                            alert('Lỗi: ' + res.message);
                            checkbox.prop('checked', !checkbox.prop('checked'));
                        }
                    },
                    error: function() {
                        alert('Không thể kết nối đến server.');
                        checkbox.prop('checked', !checkbox.prop('checked'));
                    }
                });
            });

            // Xử lý bật tắt Khuyến mãi và nhập giá sale
            $('.promo-toggle').on('change', function() {
                var checkbox = $(this);
                var id = checkbox.data('id');
                var isChecked = checkbox.is(':checked');
                var normalPrice = parseFloat(checkbox.data('price'));
                
                var salePrice = null;
                if (isChecked) {
                    var input = prompt("Nhập giá Khuyến mãi (đ) cho sản phẩm (Giá hiện tại: " + normalPrice.toLocaleString('vi-VN') + " đ):");
                    if (input === null) {
                        // Người dùng nhấn Cancel
                        checkbox.prop('checked', false);
                        return;
                    }
                    
                    salePrice = parseFloat(input.replace(/[^0-9]/g, ''));
                    if (isNaN(salePrice) || salePrice <= 0 || salePrice >= normalPrice) {
                        alert("Giá khuyến mãi phải lớn hơn 0 và nhỏ hơn giá bán gốc (" + normalPrice.toLocaleString('vi-VN') + " đ)!");
                        checkbox.prop('checked', false);
                        return;
                    }
                }
                
                $.ajax({
                    url: '/Product/ToggleStatus',
                    type: 'POST',
                    data: { id: id, type: 'IsPromo', salePrice: salePrice },
                    success: function(res) {
                        if (res.success) {
                            var badge = $('#promo-badge-' + id);
                            var priceCell = checkbox.closest('tr').find('td:nth-child(5)'); // Cột giá
                            
                            if (res.isPromo && res.salePrice) {
                                badge.removeClass('d-none');
                                var pct = Math.round(((res.price - res.salePrice) / res.price) * 100);
                                badge.text(pct + '%');
                                
                                // Cập nhật lại hiển thị giá
                                priceCell.html('<div><span class="text-danger fw-bold">' + res.salePrice.toLocaleString('vi-VN') + ' đ</span><br/><small class="text-muted text-decoration-line-through">' + res.price.toLocaleString('vi-VN') + ' đ</small></div>');
                            } else {
                                badge.addClass('d-none');
                                badge.text('');
                                priceCell.html('<span class="text-dark fw-bold">' + res.price.toLocaleString('vi-VN') + ' đ</span>');
                            }
                        } else {
                            alert('Lỗi: ' + res.message);
                            checkbox.prop('checked', !isChecked);
                        }
                    },
                    error: function() {
                        alert('Không thể kết nối đến server.');
                        checkbox.prop('checked', !isChecked);
                    }
                });
            });
        });
    </script>
}