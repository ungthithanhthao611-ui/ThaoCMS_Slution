@model List<CMS.Data.Entities.Product>

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý sản phẩm";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-dark fw-bold">DANH SÁCH SẢN PHẨM</h2>
    </div>

    <table class="table table-bordered table-striped table-hover shadow-sm">
        <thead class="table-dark">
            <tr>
                <th style="width: 80px;">ID</th>
                <th>Hình ảnh</th>
                <th>Tên sản phẩm</th>
                <th>Mô tả</th>
                <th>Giá bán</th>
                <th>Số lượng kho</th>
            </tr>
        </thead>

        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td><strong>@item.Id</strong></td>
                    <td class="text-center" style="width: 120px;">
                        <img src="@item.ImageUrl" alt="@item.Name" class="img-thumbnail" style="max-height: 60px; max-width: 100px; object-fit: cover;" onerror="this.src='https://via.placeholder.com/100x60?text=No+Image'" />
                    </td>
                    <td class="text-primary fw-semibold">@item.Name</td>
                    <td class="text-muted">@item.Description</td>
                    <td class="text-danger fw-bold">@item.Price.ToString("#,##0") VNĐ</td>
                    <td>
                        @if (item.StockQuantity <= 5)
                        {
                            <span class="badge bg-warning text-dark">Chỉ còn @item.StockQuantity</span>
                        }
                        else
                        {
                            <span class="badge bg-success">@item.StockQuantity</span>
                        }
                    </td>
                </tr>
            }
        </tbody>
    </table>

    @if (!Model.Any())
    {
        <div class="text-center text-muted my-5">
            <i class="bi bi-box display-3"></i>
            <p class="mt-3">Hệ thống chưa có sản phẩm nào.</p>
        </div>
    }
</div>