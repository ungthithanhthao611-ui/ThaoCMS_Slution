@model CMS.Data.Entities.Product

@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm sản phẩm mới";
}

<div class="container-fluid mt-4">
    <div class="card shadow border-0">
        <div class="card-header bg-success text-white py-3">
            <h5 class="mb-0 fw-bold"><i class="bi bi-box-seam"></i> THÊM SẢN PHẨM MỚI</h5>
        </div>
        <div class="card-body p-4">
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="row">
                    <!-- Cột bên trái: Các thông tin mô tả cơ bản của sản phẩm -->
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tên sản phẩm:</label>
                            <input asp-for="Name" class="form-control form-control-lg" placeholder="Nhập tên sản phẩm..." required />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Mô tả chi tiết:</label>
                            <textarea asp-for="Description" class="form-control" rows="8" placeholder="Nhập thông tin giới thiệu chi tiết về sản phẩm..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>
                    </div>

                    <!-- Cột bên phải: Giá, Số lượng, Loại sản phẩm, Trạng thái và Ảnh -->
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Loại sản phẩm:</label>
                            <select asp-for="CategoryProductId" class="form-select" asp-items="ViewBag.CategoryList" required>
                                <option value="">-- Chọn loại sản phẩm --</option>
                            </select>
                            <span asp-validation-for="CategoryProductId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Giá bán (VNĐ):</label>
                            <input asp-for="Price" type="number" step="1000" id="product-price" class="form-control" placeholder="Ví dụ: 15000000" required />
                            <span asp-validation-for="Price" class="text-danger"></span>
                        </div>

                        <!-- Khu vực trạng thái -->
                        <div class="mb-3 p-3 bg-light rounded border">
                            <label class="form-label fw-bold mb-2 text-secondary">Trạng thái sản phẩm:</label>
                            
                            <div class="form-check form-switch mb-2">
                                <input asp-for="IsNew" class="form-check-input" type="checkbox" role="switch">
                                <label class="form-check-label fw-semibold" for="IsNew">Mới (New)</label>
                            </div>

                            <div class="form-check form-switch mb-2">
                                <input asp-for="IsBestSeller" class="form-check-input" type="checkbox" role="switch">
                                <label class="form-check-label fw-semibold" for="IsBestSeller">Bán chạy</label>
                            </div>

                            <div class="form-check form-switch">
                                <input asp-for="IsPromo" class="form-check-input" type="checkbox" role="switch">
                                <label class="form-check-label fw-semibold text-danger" for="IsPromo">Khuyến mãi (Sale)</label>
                            </div>
                        </div>

                        <!-- Ô nhập giá khuyến mãi, ẩn mặc định và chỉ hiện khi IsPromo được tick -->
                        <div class="mb-3 d-none" id="promo-price-group">
                            <label class="form-label fw-bold text-danger">Giá khuyến mãi (VNĐ):</label>
                            <input asp-for="SalePrice" type="number" step="1000" class="form-control" placeholder="Ví dụ: 13000000" />
                            <span asp-validation-for="SalePrice" class="text-danger"></span>
                            <small class="text-muted">Giá khuyến mãi phải nhỏ hơn giá bán gốc.</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Số lượng kho:</label>
                            <input asp-for="StockQuantity" type="number" class="form-control" placeholder="Ví dụ: 10" required />
                            <span asp-validation-for="StockQuantity" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Tải ảnh đại diện sản phẩm:</label>
                            <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                            <small class="text-muted">Chọn tệp hình ảnh từ máy tính của bạn.</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Hoặc nhập link hình ảnh (URL):</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                            <small class="text-muted">Nếu không tải ảnh lên, bạn có thể dán liên kết URL ảnh trực tiếp vào đây.</small>
                        </div>

                        <hr />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg" id="btn-submit">
                                <i class="bi bi-check-circle"></i> Lưu sản phẩm
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại danh sách
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function() {
            var promoSwitch = $('#IsPromo');
            var promoGroup = $('#promo-price-group');
            var salePriceInput = $('#SalePrice');

            // Xử lý ẩn hiện ô nhập giá khuyến mãi
            function togglePromoGroup() {
                if (promoSwitch.is(':checked')) {
                    promoGroup.removeClass('d-none');
                    salePriceInput.prop('required', true);
                } else {
                    promoGroup.addClass('d-none');
                    salePriceInput.prop('required', false);
                    salePriceInput.val('');
                }
            }

            promoSwitch.on('change', function() {
                togglePromoGroup();
            });

            // Chạy kiểm tra ngay khi load
            togglePromoGroup();

            // Validate logic giá trước khi submit
            $('#btn-submit').on('click', function(e) {
                var price = parseFloat($('#product-price').val());
                var isPromo = promoSwitch.is(':checked');
                var salePrice = parseFloat(salePriceInput.val());

                if (isPromo) {
                    if (isNaN(salePrice) || salePrice <= 0) {
                        alert("Vui lòng nhập giá khuyến mãi hợp lệ!");
                        e.preventDefault();
                        return;
                    }
                    if (salePrice >= price) {
                        alert("Giá khuyến mãi phải nhỏ hơn giá bán gốc (" + price.toLocaleString('vi-VN') + " đ)!");
                        e.preventDefault();
                        return;
                    }
                }
            });
        });
    </script>
}
