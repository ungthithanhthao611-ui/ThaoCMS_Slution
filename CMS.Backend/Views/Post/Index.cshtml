@model List<CMS.Data.Entities.Post>

@{
    ViewData["Title"] = "Danh sách bài viết";
}

<div class="container mt-4">
    <h2 style="color:#e63946; margin: 0 0 25px 0;">
        DANH SÁCH BÀI VIẾT MỚI NHẤT
    </h2>

    <div style="display:flex; flex-wrap:wrap; gap:20px;">
        @foreach (var item in Model)
        {
            <div style="width:280px; border:1px solid #ddd; border-radius:8px; padding:12px; box-shadow:0 2px 6px rgba(0,0,0,0.08);">
                <img src="@item.ImageUrl" alt="Thumbnail"
                     style="width:100%; height:140px; object-fit:cover; border-radius:4px;"
                     onerror="this.src='https://via.placeholder.com/280x140?text=No+Image'" />

                @if (item.Category != null)
                {
                    <span class="badge bg-primary mt-2">@item.Category.Name</span>
                }

                <h4 style="color:#0d6efd; margin-top:10px;">
                    @item.Title
                </h4>

                <p>
                    @(item.Content != null && item.Content.Length > 80
                                ? item.Content.Substring(0, 80) + "..."
                                : item.Content)
                </p>

                <small>Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")</small>

                <br /><br />

                <a asp-action="Details" asp-route-id="@item.Id"
                   style="border:1px solid #0d6efd; padding:5px 10px; text-decoration:none; color:#0d6efd; border-radius:4px;">
                    Xem chi tiết
                </a>
            </div>
        }
    </div>
</div>