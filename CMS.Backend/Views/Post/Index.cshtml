@model IEnumerable<CMS.Data.Entities.Post>
@{
    // [BUỔI 4] Cấu hình sử dụng Layout quản trị chung
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Quản lý bài viết";
}

<div>
    <!-- Tiêu đề và Nút Thêm mới bài viết - [BUỔI 4] -->
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>QUẢN LÝ BÀI VIẾT</h2>
        <a asp-action="Create" class="btn btn-success">
            <i class="bi bi-plus-circle"></i> Thêm bài viết mới
        </a>
    </div>
    
    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <!-- Thumbnail của bài viết - [BUỔI 3/4] -->
                    <div style="background-color: #f8f9fa; border-bottom: 1px solid #eee; text-align: center;">
                        <img src="@item.ImageUrl" class="card-img-top p-3" alt="Thumbnail" 
                             style="height: 220px; object-fit: contain; width: 100%; transition: transform 0.3s ease;"
                             onmouseover="this.style.transform='scale(1.05)'" onmouseout="this.style.transform='scale(1)'"
                             onerror="this.onerror=null; this.src='https://placehold.co/400x220?text=No+Image'">
                    </div>
                         
                    <div class="card-body d-flex flex-column">
                        <!-- Nhãn chuyên mục được join kèm bằng .Include() - [BUỔI 3] -->
                        @if (item.Category != null)
                        {
                            <span class="badge bg-info text-dark mb-2 align-self-start">@item.Category.Name</span>
                        }
                        else
                        {
                            <span class="badge bg-secondary text-white mb-2 align-self-start">Không có danh mục</span>
                        }

                        <h5 class="card-title text-primary fw-bold">@item.Title</h5>
                        
                        <!-- Hiển thị nội dung bài viết thô (Trích đoạn ngắn) - [BUỔI 3] -->
                        <p class="card-text text-muted text-truncate flex-grow-1">
                            @* Dùng Regex để loại bỏ các thẻ HTML khi làm trích đoạn text thô *@
                            @(item.Content != null ? System.Text.RegularExpressions.Regex.Replace(item.Content, "<.*?>", string.Empty) : "")
                        </p>
                        
                        <p class="text-muted small mb-3">
                            📅 Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")
                        </p>
                        
                        <!-- Các nút Thao tác hành động: Xem chi tiết (B3), Sửa, Xóa (B4) -->
                        <div class="d-flex justify-content-between mt-auto pt-2 border-top">
                            <a href="/Post/Details/@item.Id" class="btn btn-primary btn-sm">
                                <i class="bi bi-eye"></i> Chi tiết
                            </a>
                            <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                <i class="bi bi-pencil-square"></i> Sửa
                            </a>
                            <!-- Hộp thoại confirm JavaScript ngăn ngừa việc lỡ bấm xóa nhầm - [BUỔI 4] -->
                            <a asp-action="Delete" asp-route-id="@item.Id"
                               class="btn btn-sm btn-danger"
                               onclick="return confirm('Bạn có chắc chắn muốn xóa bài viết này không?')">
                                <i class="bi bi-trash"></i> Xóa
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center text-muted my-5">
            <i class="bi bi-file-earmark-text display-1"></i>
            <p class="mt-3">Hệ thống chưa có bài viết nào. Vui lòng bấm vào nút thêm mới để tạo bài viết đầu tiên!</p>
        </div>
    }
</div>