@model List<CMS.Data.Entities.Post>

@{
    ViewData["Title"] = "Danh sách bài viết";
}

<h2 style="color:#e63946; margin: 25px 0;">
    DANH SÁCH BÀI VIẾT MỚI NHẤT
</h2>

<div style="display:flex; flex-wrap:wrap; gap:20px;">
    @foreach (var item in Model)
    {
        <div style="width:280px; border:1px solid #ddd; border-radius:8px; padding:12px;">
            <img src="@item.ImageUrl" alt="Thumbnail"
                 style="width:100%; height:140px; object-fit:cover;" />

            <h4 style="color:#0d6efd; margin-top:10px;">
                @item.Title
            </h4>

            <p>
                @(item.Content != null && item.Content.Length > 80
                            ? item.Content.Substring(0, 80) + "..."
                            : item.Content)
        </p>

            <small>
                Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")
            </small>

            <br /><br />

            <a href="#" style="border:1px solid #0d6efd; padding:5px 10px; text-decoration:none;">
                Xem chi tiết
            </a>
        </div>
        }
</div>