@model IEnumerable<CMS.Data.Entities.Post>

@{
    ViewData["Title"] = "Quản lý bài viết";
}

<div class="container mt-4">
    <h3 class="text-danger fw-bold mb-4 text-uppercase">Danh sách bài viết mới nhất</h3>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <img src="@item.ImageUrl" class="card-img-top" alt="Thumbnail" style="height: 180px; object-fit: cover;">

                    <div class="card-body">
                        <h5 class="card-title text-primary fw-bold">@item.Title</h5>

                        <p class="card-text text-muted" style="font-size: 0.9rem;">
                            @item.Content
                        </p>

                        <p class="card-text">
                            <small class="text-secondary">Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")</small>
                        </p>

                        <a href="#" class="btn btn-outline-primary btn-sm">Xem chi tiết</a>
                    </div>
                </div>
            </div>
        }
    </div>
</div>