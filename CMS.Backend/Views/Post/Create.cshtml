@model CMS.Data.Entities.Post

@{
    // [BUỔI 4] Cấu hình sử dụng Layout quản trị chung
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Thêm bài viết mới";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex align-items-center">
            <h4 class="mb-0"><i class="bi bi-file-earmark-plus"></i> THÊM BÀI VIẾT MỚI</h4>
        </div>
        <div class="card-body">
            <!-- [BUỔI 4] Lưu ý cấu hình enctype="multipart/form-data" để trình duyệt có thể upload file ảnh -->
            <form asp-action="Create" method="post" enctype="multipart/form-data">
                <div class="row">
                    <!-- Cột bên trái: Các thông tin nội dung bài viết -->
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tiêu đề bài viết:</label>
                            <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề..." required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Nội dung chi tiết:</label>
                            <!-- Textarea nội dung bài viết. Id="Content" tự sinh bởi Tag Helper sẽ được CKEditor 5 kích hoạt -->
                            <textarea asp-for="Content" class="form-control" rows="12" placeholder="Viết nội dung tại đây..."></textarea>
                        </div>
                    </div>

                    <!-- Cột bên phải: Cấu hình danh mục, hình ảnh và ngày đăng -->
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Chuyên mục bài viết:</label>
                            <!-- Dropdown danh sách chuyên mục nạp từ ViewBag.CategoryList (Buổi 4) -->
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryList" required>
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Tải ảnh đại diện mới:</label>
                            <!-- Input tải ảnh vật lý lên server (Buổi 4) -->
                            <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                            <small class="text-muted">Chọn tệp hình ảnh từ máy tính của bạn.</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Hoặc nhập link ảnh đại diện (URL):</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                            <small class="text-muted">Nếu không tải ảnh lên, bạn có thể dán liên kết URL ảnh trực tiếp vào đây.</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Ngày đăng bài:</label>
                            <input asp-for="CreatedDate" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" required />
                        </div>

                        <hr />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success btn-lg">
                                <i class="bi bi-cloud-arrow-up"></i> Lưu và Đăng bài
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại danh sách
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <!-- [BUỔI 4] Tích hợp Classic CKEditor 5 để soạn thảo văn bản giàu định dạng (Rich Text Editor) -->
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
    <script>
        // Kích hoạt CKEditor cho thẻ textarea có id là 'Content'
        ClassicEditor
            .create(document.querySelector('#Content'))
            .catch(error => {
                console.error(error);
            });
    </script>
}
