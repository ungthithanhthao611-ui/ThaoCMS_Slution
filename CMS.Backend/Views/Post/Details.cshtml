@model CMS.Data.Entities.Post

@{
    ViewData["Title"] = "Chi tiết bài viết";
}

<div class="container mt-4">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-controller="Home" asp-action="Index">Trang chủ</a></li>
            <li class="breadcrumb-item"><a asp-controller="Post" asp-action="Index">Bài viết</a></li>
            <li class="breadcrumb-item active">Chi tiết</li>
        </ol>
    </nav>

    <div class="card shadow-sm">
        <img src="@Model.ImageUrl" class="card-img-top"
             style="max-height:350px; object-fit:cover;"
             onerror="this.src='https://via.placeholder.com/800x350?text=No+Image'"
             alt="Ảnh bài viết" />
        <div class="card-body">
            @* YÊU CẦU 1: Hiển thị tên danh mục bằng .Include() *@
            <span class="badge bg-primary fs-6 mb-3">📂 Danh mục: @Model.Category?.Name</span>

            <h2 class="card-title fw-bold">@Model.Title</h2>

            <p class="text-muted small">📅 Ngày đăng: @Model.CreatedDate.ToString("dd/MM/yyyy HH:mm")</p>

            <hr />

            <div class="card-text" style="line-height:1.8; font-size:1.05rem;">
                @Model.Content
            </div>
        </div>
        <div class="card-footer">
            <a asp-action="Index" class="btn btn-outline-secondary">← Quay lại danh sách</a>
        </div>
    </div>
</div>
