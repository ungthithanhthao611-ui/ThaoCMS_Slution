@model CMS.Data.Entities.Post

@{
    // [BUỔI 4] Cấu hình sử dụng Layout quản trị chung
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Chỉnh sửa bài viết";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-warning text-dark d-flex align-items-center">
            <h4 class="mb-0"><i class="bi bi-pencil-square"></i> CHỈNH SỬA BÀI VIẾT</h4>
        </div>
        <div class="card-body">
            <!-- [BUỔI 4] Cấu hình enctype="multipart/form-data" để hỗ trợ upload tệp ảnh mới -->
            <form asp-action="Edit" method="post" enctype="multipart/form-data">
                <!-- BẮT BUỘC phải có Hidden Input để lưu giữ lại ID bài viết đang chỉnh sửa -->
                <input type="hidden" asp-for="Id" />
                
                <div class="row">
                    <!-- Cột trái: Form soạn thảo tiêu đề và nội dung -->
                    <div class="col-md-8">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Tiêu đề bài viết:</label>
                            <input asp-for="Title" class="form-control" placeholder="Nhập tiêu đề..." required />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Nội dung chi tiết:</label>
                            <!-- Textarea nội dung bài viết. Id="Content" tự sinh bởi Tag Helper sẽ được CKEditor 5 kích hoạt -->
                            <textarea asp-for="Content" class="form-control" rows="12" placeholder="Viết nội dung tại đây..."></textarea>
                        </div>
                    </div>

                    <!-- Cột phải: Cấu hình chuyên mục, ảnh đại diện và ngày đăng -->
                    <div class="col-md-4">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Chuyên mục bài viết:</label>
                            <select asp-for="CategoryId" class="form-select" asp-items="ViewBag.CategoryList" required>
                                <option value="">-- Chọn danh mục --</option>
                            </select>
                        </div>

                        <!-- Hiển thị hình ảnh hiện tại (nếu có) - [BUỔI 4] -->
                        @if (!string.IsNullOrEmpty(Model.ImageUrl))
                        {
                            <div class="mb-3">
                                <label class="form-label fw-bold">Ảnh hiện tại:</label>
                                <div class="border rounded p-2 text-center bg-light">
                                    <img src="@Model.ImageUrl" alt="Current Image" style="max-width: 100%; max-height: 120px; object-fit: contain;" />
                                </div>
                            </div>
                        }

                        <div class="mb-3">
                            <label class="form-label fw-bold">Thay thế ảnh đại diện mới:</label>
                            <input type="file" name="uploadImage" class="form-control" accept="image/*" />
                            <small class="text-muted">Chọn tệp hình ảnh mới nếu bạn muốn thay đổi ảnh cũ.</small>
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold font-monospace">Hoặc sửa link ảnh trực tiếp (URL):</label>
                            <input asp-for="ImageUrl" class="form-control" placeholder="https://..." />
                        </div>

                        <div class="mb-3">
                            <label class="form-label fw-bold">Ngày sửa đổi/Đăng:</label>
                            <input asp-for="CreatedDate" type="date" class="form-control" value="@Model.CreatedDate.ToString("yyyy-MM-dd")" required />
                        </div>

                        <hr />
                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-warning text-dark btn-lg fw-bold">
                                <i class="bi bi-cloud-arrow-up"></i> Cập nhật thay đổi
                            </button>
                            <a asp-action="Index" class="btn btn-secondary">
                                <i class="bi bi-arrow-left"></i> Quay lại danh sách
                            </a>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <!-- [BUỔI 4] Tích hợp Classic CKEditor 5 để soạn thảo văn bản giàu định dạng -->
    <script src="https://cdn.ckeditor.com/ckeditor5/39.0.1/classic/ckeditor.js"></script>
    <script>
        // Kích hoạt CKEditor cho thẻ textarea có id là 'Content' và tự động nạp dữ liệu cũ từ Model
        ClassicEditor
            .create(document.querySelector('#Content'))
            .catch(error => {
                console.error(error);
            });
    </script>
}
