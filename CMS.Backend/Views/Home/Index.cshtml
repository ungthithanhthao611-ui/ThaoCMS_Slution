@model IEnumerable<CMS.Data.Entities.Post>

@{
    ViewData["Title"] = "Trang chủ - CMS Thảo";
}

<div class="container mt-5">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-danger">TIN TỨC MỚI NHẤT</h1>
        <p class="text-muted">Tổng hợp 3 bài viết mới nhất từ hệ thống CMS</p>
        <hr />
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <img src="@item.ImageUrl" class="card-img-top" alt="Thumbnail"
                         style="height:180px; object-fit:cover;"
                         onerror="this.src='https://via.placeholder.com/400x180?text=No+Image'" />
                    <div class="card-body">
                        <span class="badge bg-primary mb-2">@item.Category?.Name</span>
                        <h5 class="card-title">@item.Title</h5>
                        <p class="card-text text-muted">
                            @(item.Content != null && item.Content.Length > 100
                                ? item.Content.Substring(0, 100) + "..."
                                : item.Content)
                        </p>
                        <a href="/Post/Details/@item.Id" class="btn btn-outline-danger btn-sm">Đọc tiếp →</a>
                    </div>
                    <div class="card-footer text-muted small">
                        📅 Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center text-muted mt-4">
            <p>Chưa có bài viết nào. Hãy thêm bài viết từ menu <strong>Post</strong>.</p>
        </div>
    }
</div>
