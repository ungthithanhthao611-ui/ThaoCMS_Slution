@model IEnumerable<CMS.Data.Entities.Post>

@inject CMS.Data.ApplicationDbContext DbContext
@{
    Layout = "_LayoutAdmin";
    ViewData["Title"] = "Trang chủ - ThaoCMS";
    var pendingOrders = DbContext.Orders.Where(o => o.Status == 0).ToList();
}

<div class="container mt-4">
    @if (pendingOrders.Any())
    {
        <div class="alert alert-warning alert-dismissible fade show shadow-sm d-flex align-items-center mb-4" role="alert">
            <i class="bi bi-exclamation-triangle-fill fs-3 text-warning me-3"></i>
            <div>
                <h5 class="alert-heading mb-1 fw-bold">🔔 THÔNG BÁO ĐƠN HÀNG MỚI!</h5>
                <p class="mb-0">Hệ thống đang có <strong>@pendingOrders.Count</strong> đơn hàng mới ở trạng thái chờ duyệt. Vui lòng bấm vào <a href="/Order" class="alert-link text-decoration-underline fw-bold text-dark">Quản lý Đơn hàng</a> để kiểm tra và duyệt đơn.</p>
            </div>
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold text-danger">TIN TỨC MỚI NHẤT</h1>
        <p class="text-muted fs-5 mb-3">Tổng hợp 3 bài viết mới nhất từ hệ thống ThaoCMS</p>
        <div class="d-inline-flex align-items-center gap-2 px-3 py-2 bg-light border rounded-pill shadow-sm mb-3">
            <span class="badge bg-danger rounded-circle p-2" style="width: 32px; height: 32px; display: inline-flex; align-items: center; justify-content: center;"><i class="bi bi-person-fill"></i></span>
            <span class="fw-semibold text-dark">Sinh viên:</span>
            <span class="text-primary fw-bold">Ung Thị Thanh Thảo_2123110174</span>
        </div>
        <hr />
    </div>

    <div class="row">
        @foreach (var item in Model)
        {
            <div class="col-md-4 mb-4">
                <div class="card shadow-sm h-100">
                    <img src="@item.ImageUrl" class="card-img-top" alt="Thumbnail"
                         style="height:180px; object-fit:cover;"
                         onerror="this.onerror=null; this.src='https://placehold.co/400x180?text=No+Image'" />
                    <div class="card-body">
                        <span class="badge bg-primary mb-2">@item.Category?.Name</span>
                        <h5 class="card-title">@item.Title</h5>
                        <p class="card-text text-muted">
                            @(item.Content != null && item.Content.Length > 100
                                ? item.Content.Substring(0, 100) + "..."
                                : item.Content)
                        </p>
                        <a href="/Post/Details/@item.Id" class="btn btn-outline-danger btn-sm">Đọc tiếp →</a>
                    </div>
                    <div class="card-footer text-muted small">
                        📅 Ngày đăng: @item.CreatedDate.ToString("dd/MM/yyyy")
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center text-muted mt-4">
            <p>Chưa có bài viết nào. Hãy thêm bài viết từ menu <strong>Post</strong>.</p>
        </div>
    }
</div>
